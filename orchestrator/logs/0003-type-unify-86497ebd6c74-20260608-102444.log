// FILE: crates/ailang-core/src/unify.rs
use crate::ty::Type;
use thiserror::Error;

#[derive(Debug, Error)]
pub enum UnifyError {
    #[error("cannot unify {0:?} with {1:?}")]
    Mismatch(Type, Type),
}

impl Type {
    pub fn unify(a: &Type, b: &Type) -> Result<Type, UnifyError> {
        match (a, b) {
            (x, y) if x == y => Ok(x.clone()),
            (Type::Var(_), t) => Ok(t.clone()),
            (Type::Option(inner_a), Type::Option(inner_b)) => {
                Self::unify(inner_a, inner_b).map(Type::Option)
            }
            (Type::Result(ok_a, err_a), Type::Result(ok_b, err_b)) => {
                let ok = Self::unify(ok_a, ok_b)?;
                let err = Self::unify(err_a, err_b)?;
                Ok(Type::Result(Box::new(ok), Box::new(err)))
            }
            (Type::Union(variants), t) => variants
                .iter()
                .find_map(|v| Self::unify(v, b).ok())
                .ok_or(UnifyError::Mismatch(a.clone(), b.clone())),
            _ => Err(UnifyError::Mismatch(a.clone(), b.clone())),
        }
    }
}
