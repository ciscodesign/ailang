```rust
// FILE: crates/ailang-core/src/ty.rs

use crate::node_id::NodeId;
use std::cmp::Ordering;

#[derive(Clone, PartialEq, Eq, Hash, Debug)]
pub enum Type {
    Text,
    Int,
    Float,
    Bool,
    Bytes,
    Option(Box<Type>),
    Result(Box<Type>, Box<Type>),  // (ok, err)
    Var(u32),                       // type variable, identified by index
    Union(Vec<Type>),               // ordered, deduplicated
    Fold(NodeId),                   // reference to a fold node by content-hash
}

impl Type {
    pub fn union(mut types: Vec<Type>) -> Type {
        if types.len() == 1 {
            return types.into_iter().next().unwrap();
        }

        types.sort_by(Type::compare_for_canonical_form);
        types.dedup();

        Type::Union(types)
    }
}

impl Ord for Type {
    fn cmp(&self, other: &Self) -> Ordering {
        Self::compare_for_canonical_form(self, other)
    }
}

impl PartialOrd for Type {
    fn partial_cmp(&self, other: &Self) -> Option<Ordering> {
        Some(self.cmp(other))
    }
}

impl Type {
    fn compare_for_canonical_form(a: &Type, b: &Type) -> Ordering {
        use Type::*;
        match (a, b) {
            (Text, Text) => Ordering::Equal,
            (Int, Int) => Ordering::Equal,
            (Float, Float) => Ordering::Equal,
            (Bool, Bool) => Ordering::Equal,
            (Bytes, Bytes) => Ordering::Equal,
            (Option(a), Option(b)) => a.cmp(b),
            (Result(a_ok, a_err), Result(b_ok, b_err)) => {
                a_ok.cmp(b_ok).then_with(|| a_err.cmp(b_err))
            }
            (Var(a), Var(b)) => a.cmp(b),
            (Union(a), Union(b)) => {
                for (a_t, b_t) in a.iter().zip(b.iter()) {
                    let cmp = Type::compare_for_canonical_form(a_t, b_t);
                    if cmp != Ordering::Equal {
                        return cmp;
                    }
                }
                a.len().cmp(&b.len())
            },
            (Fold(a), Fold(b)) => a.cmp(b),
            _ => a.debug_repr().cmp(&b.debug_repr()),
        }
    }
}
