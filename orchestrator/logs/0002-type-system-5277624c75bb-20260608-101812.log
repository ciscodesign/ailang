// FILE: crates/ailang-core/src/ty.rs

use crate::node_id::NodeId;
use std::cmp::Ordering;

#[derive(Clone, PartialEq, Eq, Hash, Debug)]
pub enum Type {
    Text,
    Int,
    Float,
    Bool,
    Bytes,
    Option(Box<Type>),
    Result(Box<Type>, Box<Type>),  // (ok, err)
    Var(u32),                       // type variable, identified by index
    Union(Vec<Type>),               // ordered, deduplicated
    Fold(NodeId),                   // reference to a fold node by content-hash
}

impl Type {
    pub fn union(mut types: Vec<Type>) -> Type {
        if types.len() <= 1 {
            return types.into_iter().next().unwrap_or(Type::Union(vec![]));
        }

        // Sort and deduplicate the types
        types.sort();
        types.dedup();

        if types.len() == 1 {
            types.into_iter().next().unwrap()
        } else {
            Type::Union(types)
        }
    }
}

impl Ord for Type {
    fn cmp(&self, other: &Self) -> Ordering {
        use Type::*;
        match (self, other) {
            (Text, Text) => Ordering::Equal,
            (Int, Int) => Ordering::Equal,
            (Float, Float) => Ordering::Equal,
            (Bool, Bool) => Ordering::Equal,
            (Bytes, Bytes) => Ordering::Equal,
            (Option(a), Option(b)) => a.cmp(b),
            (Result(a1, e1), Result(a2, e2)) => {
                let ord = a1.cmp(a2);
                if ord == Ordering::Equal {
                    e1.cmp(e2)
                } else {
                    ord
                }
            },
            (Var(a), Var(b)) => a.cmp(b),
            (Union(a), Union(b)) => {
                for (ta, tb) in a.iter().zip(b.iter()) {
                    let ord = ta.cmp(tb);
                    if ord != Ordering::Equal {
                        return ord;
                    }
                }
                a.len().cmp(&b.len())
            },
            (Fold(a), Fold(b)) => a.cmp(b),
            _ => self.debug_ordering(other),
        }
    }
}

impl PartialOrd for Type {
    fn partial_cmp(&self, other: &Self) -> Option<Ordering> {
        Some(self.cmp(other))
    }
}

impl Type {
    fn debug_ordering(&self, other: &Type) -> Ordering {
        use std::fmt::Debug;
        let self_name = format!("{:?}", self);
        let other_name = format!("{:?}", other);

        if self_name < other_name {
            Ordering::Less
        } else if self_name > other_name {
            Ordering::Greater
        } else {
            Ordering::Equal
        }
    }
}
```

