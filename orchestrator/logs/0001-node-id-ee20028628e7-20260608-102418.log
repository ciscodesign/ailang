```rust
// FILE: crates/ailang-core/src/node_id.rs
use std::fmt;
use blake3::hash_bytes;

/// Content-addressed identifier for a node.
///
/// A `NodeId` is the blake3 hash of a node's canonical byte encoding.
#[derive(Clone, Copy, PartialEq, Eq, Hash, Debug)]
pub struct NodeId([u8; 32]);

impl NodeId {
    /// Computes the `NodeId` from the canonical bytes of a node.
    pub fn of(bytes: &[u8]) -> Self {
        let hash = hash_bytes(bytes);
        NodeId(*hash.as_bytes())
    }

    /// Returns the raw 32-byte hash value.
    pub fn as_bytes(&self) -> &[u8; 32] {
        &self.0
    }
}

impl fmt::Display for NodeId {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        write!(f, "blake3:")?;
        // First 12 hex characters correspond to the first 6 bytes.
        for byte in self.0.iter().take(6) {
            write!(f, "{:02x}", byte)?;
        }
        Ok(())
    }
}
```

